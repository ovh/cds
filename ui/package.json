    "ng-zorro-antd": "21.3.1",
    "ng2-completer": "2.0.8",
    "ng2-dragula": "6.0.0",
    "ngx-clipboard": "16.0.0",
    "ngx-infinite-scroll": "21.0.0",
    "ngx-markdown": "21.3.0",
    "ngx-moment": "6.0.2",
