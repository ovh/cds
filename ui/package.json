{
  "name": "ui-ng2",
  "version": "0.0.0",
  "angular-cli": {},
  "engines": {
    "node": ">= 22.0.0",
    "npm": ">= 8.5.0"
  },
  "scripts": {
    "ng": "ng",
    "start": "ng serve -c development",
    "experimental": "ng serve -c experimental",
    "test": "ng test --watch false --code-coverage",
    "e2e": "testcafe chromium:headless ./e2e/tests/* -S -s screenshots",
    "doc": "./node_modules/.bin/compodoc -p tsconfig.json -s",
    "build:prod": "ng build ui-ng2 --configuration production",
    "build:stats": "ng build ui-ng2 --configuration production --stats-json",
    "build:analyse": "webpack-bundle-analyzer dist/stats.json",
    "sentry:release": "sentry-cli releases -o ${SENTRY_ORG} -p ${SENTRY_PROJECT} new ${CDS_VERSION}",
    "sentry:sourcemaps": "sentry-cli releases -o ${SENTRY_ORG} -p ${SENTRY_PROJECT} files ${CDS_VERSION} upload-sourcemaps --url-prefix=${SENTRY_CDS_PREFIX_URL}",
    "lint": "ng lint"
  },
  "lint-staged": {
    "*.{js,ts}": "eslint"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "21.2.17",
    "@angular/cdk": "21.2.14",
    "@angular/common": "21.2.17",
    "@angular/compiler": "21.2.17",
    "@angular/core": "21.2.17",
    "@angular/forms": "21.2.17",
    "@angular/platform-browser": "21.2.17",
    "@angular/platform-browser-dynamic": "21.2.17",
    "@angular/router": "21.2.17",
    "@babel/runtime": "7.28.6",
    "@fontsource/lato": "5.2.7",
    "@icholy/duration": "5.1.0",
    "@ngx-translate/core": "15.0.0",
    "@ngx-translate/http-loader": "8.0.0",
    "@ngxs/devtools-plugin": "21.0.0",
    "@ngxs/logger-plugin": "21.0.0",
    "@ngxs/storage-plugin": "21.0.0",
    "@ngxs/store": "21.0.0",
    "@swimlane/ngx-charts": "20.5.0",
    "@types/dagre-d3": "0.6.2",
    "@types/js-yaml": "3.12.10",
    "@types/zxcvbn": "4.4.5",
    "angular2-prettyjson": "3.0.1",
    "animate.css": "3.7.2",
    "ansi_up": "5.2.1",
    "codemirror": "5.65.21",
    "core-js": "3.48.0",
    "d3": "7.8.5",
    "d3-zoom": "3.0.0",
