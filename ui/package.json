    "diff": "4.0.4",
    "dragula": "3.7.3",
    "enhanced-resolve": "4.5.0",
    "fast-json-patch": "3.1.1",
    "font-awesome": "4.7.0",
    "immutable": "4.3.8",
    "jquery": "3.7.1",
    "js-beautify": "1.15.4",
    "js-yaml": "4.1.1",
    "jsonschema": "1.5.0",
    "jsrsasign": "11.1.1",
